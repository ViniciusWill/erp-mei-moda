# Use esta variavel apenas no ambiente local.
# Cole aqui a Internal/External Database URL do banco PostgreSQL de teste.
TEST_DATABASE_URL=postgresql://usuario:senha@host:5432/banco_teste

# Use esta variavel apenas no ambiente local, quando quiser copiar
# os dados de producao para o banco de teste.
PROD_DATABASE_URL=postgresql://usuario:senha@host:5432/banco_producao

# No Render, configure DATABASE_URL com o banco PostgreSQL de producao.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco_producao
